rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 本のページ画像（認証済みユーザーなら読み取り可）
    match /books/{bookId}/pages/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // 隊長のみの制限は別途Firestoreで管理
    }

    // 表紙画像
    match /books/{bookId}/cover.jpg {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // 課題提出ファイル（認証済みユーザーなら読み書き可）
    match /submissions/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // その他すべて拒否
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
